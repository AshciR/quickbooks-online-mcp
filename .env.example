# Intuit developer app credentials (developer.intuit.com)
INTUIT_CLIENT_ID=your-intuit-client-id
INTUIT_CLIENT_SECRET=your-intuit-client-secret

# Populated by scripts/bootstrap_oauth.py — leave blank initially.
QBO_REALM_ID=

# sandbox | production
QBO_ENVIRONMENT=sandbox

# Upstash Redis REST credentials (console.upstash.com)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Shared secret presented by MCP clients via Authorization: Bearer ...
MCP_BEARER_TOKEN=generate-a-long-random-string
