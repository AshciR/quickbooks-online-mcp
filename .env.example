# Intuit developer app credentials (developer.intuit.com)
INTUIT_CLIENT_ID=your-intuit-client-id
INTUIT_CLIENT_SECRET=your-intuit-client-secret

# Populated by scripts/bootstrap_oauth.py — leave blank initially.
QBO_REALM_ID=

# sandbox | production. Token bundles are namespaced by this value in Redis
# (qbo:tokens:sandbox vs qbo:tokens:production), so the two never clobber each
# other. To run against production, copy this file to .env.prod with the
# production Intuit keys + QBO_ENVIRONMENT=production, then point the scripts at
# it: `ENV_FILE=.env.prod uv run python scripts/bootstrap_oauth.py`.
QBO_ENVIRONMENT=sandbox

# Upstash Redis REST credentials (console.upstash.com)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Inbound MCP-client auth mode: bearer | oauth. Default is bearer.
#
# bearer — clients present a shared static token via `Authorization: Bearer ...`.
#   Works from header-capable clients (Claude Code CLI, MCP Inspector, curl). Set
#   MCP_BEARER_TOKEN below. NOTE: Claude Desktop's custom-connector dialog has no
#   header field, so it CANNOT use bearer mode — use oauth for that client.
#
# oauth — the server runs a WorkOS AuthKit OAuth provider; only users invited in the
#   WorkOS directory can connect (Claude Desktop self-registers via DCR, so its OAuth
#   Client ID/Secret fields stay blank). Set AUTHKIT_DOMAIN and MCP_SERVER_BASE_URL;
#   MCP_BEARER_TOKEN is not needed.
MCP_AUTH_MODE=bearer

# Required when MCP_AUTH_MODE=bearer. Shared secret presented by MCP clients.
MCP_BEARER_TOKEN=generate-a-long-random-string

# Required when MCP_AUTH_MODE=oauth (otherwise leave blank/unset).
# AUTHKIT_DOMAIN — the WorkOS AuthKit domain that issues/validates tokens.
# MCP_SERVER_BASE_URL — the server's public HTTPS URL, so OAuth discovery metadata
#   and redirect URIs are correct (e.g. https://<app>.onrender.com).
# AUTHKIT_DOMAIN=https://your-app.authkit.app
# MCP_SERVER_BASE_URL=https://your-app.onrender.com

# OAuth redirect URI for scripts/bootstrap_oauth.py. Defaults to
# http://localhost:8000/callback (accepted by sandbox keys). Production Intuit
# keys reject localhost/IP URIs, so set this to a public HTTPS tunnel callback
# (e.g. https://<subdomain>.ngrok-free.app/callback) — it must match the URI
# registered in the Intuit app exactly. Only needed for the one-time handshake.
# OAUTH_REDIRECT_URI=http://localhost:8000/callback
